{
  "name": "@butchi/matra-html",
  "description": "HTML renderer for Matra AST",
  "version": "0.9.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
