{
  "name": "@matralang/core",
  "description": "Domain-neutral AST, parser, visitor, and transformer for Matra",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/matra-parser.pegjs"
  ],
  "workspaces": [
    "matra-html"
  ],
  "scripts": {
    "build": "npm run build:parser && npm run build:types",
    "build:all": "npm run build && npm run build --workspace @matralang/matra-html",
    "build:parser": "peggy --format es --output src/matra-parser.mjs src/matra-parser.pegjs",
    "build:types": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build:all && node --test tests/core.test.mjs matra-html/tests/html.test.mjs",
    "test:legacy": "npm run build && node --test tests/*.test.mjs",
    "prepack": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matralang/core.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "peggy": "^5.0.6",
    "typescript": "^5.9.3"
  }
}
